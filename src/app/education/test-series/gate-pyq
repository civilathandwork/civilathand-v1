        ${s.free ? '▶ Start Exam' : '🔒 Unlock (Coming Soon)'}
      </button>
    `;
    grid.appendChild(card);
  });
}

function startExam(subjectId) {
  currentSubject = SUBJECTS.find(s => s.id === subjectId);
  if (!currentSubject) return;

  // For now, only Soil Mechanics has full data. Others show sample.
  if (QUESTIONS[subjectId]) {
    questions = QUESTIONS[subjectId];
  } else {
    // Generate sample questions for other subjects
    questions = generateSampleQuestions(currentSubject);
  }

  answers = {};
  reviewed = {};
  visited = {};
  currentQ = 0;
  timerSec = 3 * 3600;

  // Set names
  document.getElementById('exam-bar-name').textContent = `CE Civil Engineering PYQ — ${currentSubject.name}`;
  document.getElementById('section-tab-name').textContent = currentSubject.name;
  document.getElementById('palette-section-title').textContent = currentSubject.name;
  document.getElementById('sidebar-exam-name').textContent = 'GATE CE PYQ';
  document.getElementById('result-subject-label').textContent = `${currentSubject.name} · GATE PYQ`;

  // Hide subject screen, show exam screen
  document.getElementById('subject-screen').style.display = 'none';
  document.getElementById('result-screen').style.display = 'none';
  const examScreen = document.getElementById('exam-screen');
  examScreen.style.display = 'flex';

  buildPalette();
  goToQuestion(0);
  startTimer();
}

function generateSampleQuestions(subject) {
  // Generate 10 placeholder questions for subjects without full data yet
  const samples = [];
  for (let i = 1; i <= 10; i++) {
    samples.push({
      id: i, type: 'MCQ', marks: 2, neg: '2/3', year: 'GATE-2022',
      question: `[Sample Question ${i}] This is a placeholder for ${subject.name}. Upload your full question data for this subject to see real PYQ questions here. Your IES Master book (pages ${subject.pages}) contains all questions.`,
      options: ['(a) Option A (Correct)', '(b) Option B', '(c) Option C', '(d) Option D'],
      correct: 0,
      solution: `Sample solution for ${subject.name} Question ${i}. Add real data from your book pages ${subject.pages}.`
    });
  }
  return samples;
}

// ====== PALETTE ======
function buildPalette() {
  const grid = document.getElementById('palette-grid');
  grid.innerHTML = '';
  questions.forEach((q, i) => {
    const btn = document.createElement('button');
    btn.className = 'pal-btn';
    btn.textContent = i + 1;
    btn.id = `pal-${i}`;
    btn.onclick = () => goToQuestion(i);
    grid.appendChild(btn);
  });
  updatePalette();
}

function updatePalette() {
  const total = questions.length;
  let cntAns = 0, cntNotAns = 0, cntNotVis = 0, cntMark = 0;
  questions.forEach((q, i) => {
    const btn = document.getElementById(`pal-${i}`);
    if (!btn) return;
    btn.className = 'pal-btn';
    const isAnswered = answers[i] !== undefined;
    const isMarked = reviewed[i];
    const isVisited = visited[i];
    const isCurrent = i === currentQ;

    if (isCurrent) { btn.classList.add('current'); }
    else if (isAnswered && isMarked) { btn.classList.add('answered-marked'); cntMark++; }
    else if (isAnswered) { btn.classList.add('answered'); cntAns++; }
    else if (isMarked) { btn.classList.add('marked'); cntMark++; }
    else if (isVisited) { btn.classList.add('not-visited-style'); cntNotAns++; }
    else { cntNotVis++; }
  });
  document.getElementById('cnt-answered').textContent = cntAns;
  document.getElementById('cnt-not-answered').textContent = cntNotAns;
  document.getElementById('cnt-not-visited').textContent = cntNotVis;
  document.getElementById('cnt-marked').textContent = cntMark;
  document.getElementById('q-counter').textContent = `Question ${currentQ + 1} of ${questions.length}`;
}

// ====== QUESTION RENDER ======
function goToQuestion(idx) {
  currentQ = idx;
  visited[idx] = true;
  renderQuestion();
  updatePalette();
}

function renderQuestion() {
