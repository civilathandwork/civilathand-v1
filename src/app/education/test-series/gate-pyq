  html += `</div>`;

  // Show Solution button (always visible for PYQ)
  html += `<button class="show-sol-btn" onclick="toggleSolution(this)">💡 Show Solution</button>`;
  html += `<div class="solution-panel" id="solution-panel">
    <div class="sol-title">✅ Answer & Solution</div>
    <div class="sol-answer">Correct Answer: ${q.options ? q.options[q.correct] : '—'}</div>
    <div class="sol-text">${q.solution}</div>
  </div>`;

  document.getElementById('q-content').innerHTML = html;
}

function toggleSolution(btn) {
  const panel = document.getElementById('solution-panel');
  if (panel.classList.contains('show')) {
    panel.classList.remove('show');
    btn.textContent = '💡 Show Solution';
  } else {
    panel.classList.add('show');
    btn.textContent = '🙈 Hide Solution';
  }
}

function selectOption(idx) {
  answers[currentQ] = idx;
  // Update visual
  document.querySelectorAll('.q-option').forEach((el, i) => {
    el.classList.toggle('selected', i === idx);
    const radio = document.getElementById(`opt-r-${i}`);
    if (radio) radio.checked = i === idx;
  });
  updatePalette();
}

function handleNAT(val) {
  answers[currentQ] = val;
  updatePalette();
}

// ====== ACTIONS ======
function saveAndNext() {
  nextQuestion();
}

function nextQuestion() {
  if (currentQ < questions.length - 1) goToQuestion(currentQ + 1);
}

function prevQuestion() {
  if (currentQ > 0) goToQuestion(currentQ - 1);
}

function markForReview() {
  reviewed[currentQ] = true;
  nextQuestion();
  updatePalette();
}

function clearResponse() {
  delete answers[currentQ];
  delete reviewed[currentQ];
  renderQuestion();
  updatePalette();
}

// ====== TIMER ======
function startTimer() {
  clearInterval(timerInterval);
  timerInterval = setInterval(() => {
    timerSec--;
    if (timerSec <= 0) { clearInterval(timerInterval); autoSubmit(); return; }
    const h = String(Math.floor(timerSec / 3600)).padStart(3,'0');
    const m = String(Math.floor((timerSec % 3600)/60)).padStart(2,'0');
    const s = String(timerSec % 60).padStart(2,'0');
    const el = document.getElementById('timer-display');
    el.textContent = `${h}:${m}:${s}`;
    el.className = 'timer-value' + (timerSec < 300 ? ' warning' : '');
  }, 1000);
}

function autoSubmit() {
  submitExam();
}

// ====== SUBMIT ======
function showSubmitModal() {
  const stats = getStats();
  document.getElementById('sm-answered').textContent = stats.answered;
  document.getElementById('sm-notans').textContent = stats.notAnswered;
  document.getElementById('sm-marked').textContent = stats.marked;
  document.getElementById('sm-notvis').textContent = stats.notVisited;
  document.getElementById('submit-modal').classList.add('show');
}

function getStats() {
  let answered = 0, marked = 0, notVisited = 0, notAnswered = 0;
  questions.forEach((q, i) => {
    const isAnswered = answers[i] !== undefined;
    const isMarked = reviewed[i];
    const isVisited = visited[i];
    if (isAnswered && isMarked) { answered++; marked++; }
    else if (isAnswered) answered++;
    else if (isMarked) marked++;
    else if (isVisited) notAnswered++;
    else notVisited++;
  });
  return { answered, marked, notVisited, notAnswered };
}

function submitExam() {
  clearInterval(timerInterval);
  closeModal('submit-modal');

  let correct = 0, wrong = 0, unattempted = 0, totalMarks = 0, maxMarks = 0;
  questions.forEach((q, i) => {
    maxMarks += q.marks;
    if (answers[i] === undefined) { unattempted++; return; }
    if (answers[i] === q.correct) {
      correct++;
      totalMarks += q.marks;
    } else {
      wrong++;
      // Negative marking
      const neg = parseFloat(q.neg.split('/')[0]) / parseFloat(q.neg.split('/')[1] || 1);
      totalMarks -= neg;
    }
  });
  totalMarks = Math.max(0, totalMarks);
  const pct = Math.round((totalMarks / maxMarks) * 100);
  const stats = getStats();

  // Populate results
  document.getElementById('result-score').textContent = totalMarks.toFixed(2);
  document.getElementById('result-max').textContent = `/ ${maxMarks}`;
  document.getElementById('result-percent').textContent = `${pct}% Score — ${pct >= 70 ? '🎉 Excellent!' : pct >= 50 ? '👍 Good Attempt' : '📚 Keep Practicing'}`;
  document.getElementById('result-bar').style.width = pct + '%';
  document.getElementById('res-correct').textContent = correct;
  document.getElementById('res-wrong').textContent = wrong;
  document.getElementById('res-unattempted').textContent = unattempted;
  document.getElementById('res-marked').textContent = stats.marked;

  // Answer key
  let reviewHTML = '';
  questions.forEach((q, i) => {
    const userAns = answers[i];
    const isCorrect = userAns === q.correct;
    const isUnattempted = userAns === undefined;
    const color = isUnattempted ? '#9e9e9e' : isCorrect ? '#2e7d32' : '#c62828';
    const icon = isUnattempted ? '⬜' : isCorrect ? '✅' : '❌';
    reviewHTML += `<div style="border:1px solid #e0e0e0;border-radius:4px;padding:12px;margin-bottom:10px;border-left:4px solid ${color};">
      <div style="display:flex;align-items:center;gap:8px;margin-bottom:6px;">
        <span style="font-size:15px">${icon}</span>
        <strong style="font-size:13px">Q${i+1}</strong>
        <span style="font-size:11px;color:#888">${q.year}</span>
        <span style="margin-left:auto;font-size:11px;color:${color};font-weight:700;">${isUnattempted ? 'Not Attempted' : isCorrect ? '+'+q.marks : '−'+q.neg}</span>
      </div>
      <div style="font-size:12px;color:#333;margin-bottom:6px;font-family:Georgia,serif;">${q.question.substring(0,120)}...</div>
      ${!isUnattempted ? `<div style="font-size:11px">Your answer: <strong>${q.options[userAns]}</strong></div>` : ''}
      <div style="font-size:11px;color:#2e7d32">Correct: <strong>${q.options[q.correct]}</strong></div>
    </div>`;
  });
  document.getElementById('result-review-list').innerHTML = reviewHTML;

  // Show result screen
  document.getElementById('exam-screen').style.display = 'none';
  const rs = document.getElementById('result-screen');
  rs.style.display = 'flex';
  rs.style.flexDirection = 'column';
}

function retakeExam() {
  if (currentSubject) startExam(currentSubject.id);
}

function showSubjectScreen() {
  document.getElementById('result-screen').style.display = 'none';
  document.getElementById('exam-screen').style.display = 'none';
  document.getElementById('subject-screen').style.display = 'flex';
}

// ====== MODALS ======
function showInstructions() {
  document.getElementById('instructions-modal').classList.add('show');
}

function closeModal(id) {
  document.getElementById(id).classList.remove('show');
}

// ====== CALCULATOR ======
function toggleCalc() {
  calcVisible = !calcVisible;
  const overlay = document.getElementById('calc-overlay');
  overlay.classList.toggle('show', calcVisible);
}

function minimizeCalc() {
  calcVisible = false;
  document.getElementById('calc-overlay').classList.remove('show');
}

function calcInput(val) {
  if (calcStr === '0' && val !== '.') calcStr = '';
  if (val === 'π') { calcStr += Math.PI.toFixed(10); }
  else { calcStr += val; }
  document.getElementById('calc-display').textContent = calcStr || '0';
}

function calcClear() {
  calcStr = '';
  calcExpr = '';
  document.getElementById('calc-display').textContent = '0';
  document.getElementById('calc-expr').textContent = '';
}

function calcBackspace() {
  calcStr = calcStr.slice(0, -1);
  document.getElementById('calc-display').textContent = calcStr || '0';
}

function calcEquals() {
  try {
    let expr = calcStr
      .replace(/π/g, Math.PI)
      .replace(/×/g, '*')
      .replace(/÷/g, '/')
      .replace(/−/g, '-');
    const result = Function('"use strict"; return (' + expr + ')')();
    document.getElementById('calc-expr').textContent = calcStr + ' =';
    calcStr = String(parseFloat(result.toFixed(10)));
    document.getElementById('calc-display').textContent = calcStr;
  } catch(e) {
    document.getElementById('calc-display').textContent = 'Error';
    calcStr = '';
  }
}

function calcFn(fn) {
  const val = parseFloat(calcStr) || 0;
  let result;
  const toRad = calcDeg ? (v => v * Math.PI / 180) : (v => v);
  const fromRad = calcDeg ? (v => v * 180 / Math.PI) : (v => v);
  switch(fn) {
    case 'sin': result = Math.sin(toRad(val)); break;
    case 'cos': result = Math.cos(toRad(val)); break;
    case 'tan': result = Math.tan(toRad(val)); break;
    case 'asin': result = fromRad(Math.asin(val)); break;
    case 'acos': result = fromRad(Math.acos(val)); break;
    case 'atan': result = fromRad(Math.atan(val)); break;
    case 'sinh': result = Math.sinh(val); break;
    case 'cosh': result = Math.cosh(val); break;
    case 'tanh': result = Math.tanh(val); break;
    case 'asinh': result = Math.asinh(val); break;
    case 'acosh': result = Math.acosh(val); break;
    case 'atanh': result = Math.atanh(val); break;
    case 'log': result = Math.log10(val); break;
    case 'ln': result = Math.log(val); break;
    case 'exp': calcStr += 'e'; document.getElementById('calc-display').textContent = calcStr; return;
    case 'x2': result = val * val; break;
    case 'x3': result = val * val * val; break;
    case 'xpowy': calcStr += '^'; document.getElementById('calc-display').textContent = calcStr; return;
    case 'sqrt': result = Math.sqrt(val); break;
    case 'pow10': result = Math.pow(10, val); break;
    case 'epow': result = Math.exp(val); break;
    case 'fact': result = factorial(Math.floor(val)); break;
    case 'pm': result = -val; break;
    case 'abs': result = Math.abs(val); break;
    case 'e': calcStr += '2.718281828'; document.getElementById('calc-display').textContent = calcStr; return;
    case 'mod': calcStr += '%'; document.getElementById('calc-display').textContent = calcStr; return;
    default: return;
  }
  calcStr = String(parseFloat(result.toFixed(10)));
  document.getElementById('calc-display').textContent = calcStr;
}

function factorial(n) {
  if (n <= 1) return 1;
  return n * factorial(n - 1);
}

function calcMem(cmd) {
  const val = parseFloat(calcStr) || 0;
  switch(cmd) {
    case 'MC': calcMemory = 0; break;
    case 'MR': calcStr = String(calcMemory); document.getElementById('calc-display').textContent = calcStr; break;
    case 'MS': calcMemory = val; break;
    case 'M+': calcMemory += val; break;
    case 'M-': calcMemory -= val; break;
  }
}

function setDegRad(mode) {
  calcDeg = mode === 'deg';
}

// Draggable calculator
const calcEl = document.getElementById('calculator');
const dragHandle = document.getElementById('calc-drag-handle');
dragHandle.addEventListener('mousedown', (e) => {
  isDragging = true;
  dragOffX = e.clientX - calcEl.getBoundingClientRect().left;
  dragOffY = e.clientY - calcEl.getBoundingClientRect().top;
  e.preventDefault();
});
document.addEventListener('mousemove', (e) => {
  if (!isDragging) return;
  calcEl.style.left = (e.clientX - dragOffX) + 'px';
  calcEl.style.top = (e.clientY - dragOffY) + 'px';
  calcEl.style.right = 'auto';
});
document.addEventListener('mouseup', () => { isDragging = false; });

// Close modals on overlay click
document.querySelectorAll('.modal-overlay').forEach(modal => {
  modal.addEventListener('click', (e) => {
    if (e.target === modal) modal.classList.remove('show');
  });
});

// ====== INIT ======
renderSubjects('all');
</script>
