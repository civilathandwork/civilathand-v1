  renderSubjects(cat);
}

function renderSubjects(cat = 'all') {
  const grid = document.getElementById('subject-grid');
  grid.innerHTML = '';
  SUBJECTS.forEach(s => {
    if (cat !== 'all' && s.category !== cat) return;
    const card = document.createElement('div');
    card.className = 'subject-card';
