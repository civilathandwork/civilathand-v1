<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>GATE PYQ — Civil At Hand Education</title>
<style>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
  :root {
    --blue: #1a5fb4;
    --blue-dark: #134490;
    --blue-light: #e8f0fb;
    --green: #2e7d32;
    --green-bg: #4caf50;
    --red: #c0392b;
    --red-bg: #e53935;
    --orange: #e65100;
    --purple: #6a1b9a;
    --purple-bg: #9c27b0;
    --grey-bg: #f1f1f1;
    --white: #ffffff;
    --border: #d0d0d0;
    --text: #1a1a1a;
    --text-sub: #555;
    --header-h: 68px;
    --bar-h: 36px;
  }
  body { font-family: Arial, sans-serif; font-size: 14px; background: var(--grey-bg); color: var(--text); }

  /* ====== SUBJECT SELECTION SCREEN ====== */
  #subject-screen {
    min-height: 100vh;
    background: var(--grey-bg);
    display: flex;
    flex-direction: column;
  }
  .sel-header {
    background: var(--blue);
    color: #fff;
    padding: 0 32px;
    height: var(--header-h);
    display: flex;
    align-items: center;
    gap: 16px;
    box-shadow: 0 2px 4px rgba(0,0,0,.2);
  }
  .sel-header .logo-box {
    width: 44px; height: 44px; background: #fff; border-radius: 4px;
    display: flex; align-items: center; justify-content: center;
    font-weight: 900; font-size: 13px; color: var(--blue); letter-spacing: -.5px;
    flex-shrink: 0;
  }
  .sel-header h1 { font-size: 17px; font-weight: 700; letter-spacing: .4px; }
  .sel-header p { font-size: 11px; color: rgba(255,255,255,.75); margin-top: 2px; }
  .sel-header .back-btn {
    margin-left: auto;
    background: rgba(255,255,255,.15);
    border: 1px solid rgba(255,255,255,.3);
    color: #fff;
    padding: 7px 18px;
    font-size: 12px;
    cursor: pointer;
    border-radius: 3px;
    text-decoration: none;
    font-family: Arial, sans-serif;
  }
  .sel-header .back-btn:hover { background: rgba(255,255,255,.25); }

  .sel-exam-bar {
    background: #222;
    color: #fff;
    padding: 0 32px;
    height: 38px;
    display: flex;
    align-items: center;
    font-size: 13px;
    font-weight: 700;
    letter-spacing: .5px;
    gap: 12px;
  }
  .sel-exam-bar span { color: #f9a825; font-size: 11px; font-weight: 400; }

  .sel-body { flex: 1; max-width: 1100px; margin: 0 auto; width: 100%; padding: 32px 24px 48px; }
  .sel-intro { margin-bottom: 28px; }
  .sel-intro h2 { font-size: 20px; font-weight: 700; color: var(--blue); margin-bottom: 6px; }
  .sel-intro p { font-size: 13px; color: var(--text-sub); }

  .sel-filters {
    display: flex; gap: 10px; margin-bottom: 24px; flex-wrap: wrap;
  }
  .sel-filter-btn {
    padding: 6px 16px; border: 1px solid var(--border); border-radius: 3px;
    background: #fff; font-size: 12px; cursor: pointer; font-family: Arial, sans-serif;
    color: var(--text); transition: all .15s;
  }
  .sel-filter-btn.active, .sel-filter-btn:hover {
    background: var(--blue); color: #fff; border-color: var(--blue);
  }

  .subject-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(230px, 1fr));
    gap: 14px;
  }
  .subject-card {
    background: #fff;
    border: 1px solid var(--border);
    border-radius: 4px;
    padding: 18px 16px;
    cursor: pointer;
    transition: border-color .15s, box-shadow .15s;
    position: relative;
    overflow: hidden;
  }
  .subject-card:hover {
    border-color: var(--blue);
    box-shadow: 0 2px 10px rgba(26,95,180,.15);
  }
  .subject-card::before {
    content: '';
    position: absolute; top: 0; left: 0; right: 0; height: 3px;
    background: var(--blue);
  }
  .subject-card .sub-num {
    font-size: 11px; font-weight: 700; color: var(--blue);
    text-transform: uppercase; letter-spacing: .6px; margin-bottom: 8px;
  }
  .subject-card h3 { font-size: 14px; font-weight: 700; color: var(--text); margin-bottom: 6px; line-height: 1.3; }
  .subject-card .sub-meta {
    font-size: 11px; color: var(--text-sub); display: flex; gap: 10px; flex-wrap: wrap; margin-top: 8px;
  }
  .subject-card .sub-meta span { display: flex; align-items: center; gap: 3px; }
  .subject-card .sub-qs { font-size: 11px; background: var(--blue-light); color: var(--blue); padding: 2px 8px; border-radius: 10px; font-weight: 700; margin-top: 8px; display: inline-block; }
  .subject-card .start-btn {
    margin-top: 12px; width: 100%; padding: 8px; background: var(--blue); color: #fff;
    border: none; border-radius: 3px; font-size: 12px; font-weight: 700;
    cursor: pointer; font-family: Arial, sans-serif; letter-spacing: .3px;
    transition: background .15s;
  }
  .subject-card .start-btn:hover { background: var(--blue-dark); }
  .subject-card .lock-badge {
    position: absolute; top: 10px; right: 10px;
    background: #f9a825; color: #333; font-size: 9px; font-weight: 700;
    padding: 2px 7px; border-radius: 10px; text-transform: uppercase;
  }

  .sel-note {
    margin-top: 28px; background: #fff; border: 1px solid var(--border);
    border-left: 4px solid var(--blue); padding: 14px 18px; border-radius: 4px;
    font-size: 12px; color: var(--text-sub); line-height: 1.6;
  }

  /* ====== EXAM INTERFACE ====== */
  #exam-screen {
    display: none;
    height: 100vh;
    flex-direction: column;
    overflow: hidden;
  }

  /* Top Header */
  .exam-header {
    background: #fff;
    border-bottom: 2px solid var(--border);
    height: var(--header-h);
    display: flex;
    align-items: center;
    padding: 0 16px;
    gap: 12px;
    flex-shrink: 0;
    z-index: 100;
  }
  .exam-header .gate-logo {
    width: 52px; height: 52px; background: var(--blue); border-radius: 50%;
    display: flex; align-items: center; justify-content: center;
    font-size: 10px; font-weight: 900; color: #fff; text-align: center; line-height: 1.2;
    flex-shrink: 0; border: 2px solid var(--blue-dark);
  }
  .exam-header .gate-title { flex: 1; text-align: center; }
  .exam-header .gate-title h2 { font-size: 15px; font-weight: 700; color: var(--blue); letter-spacing: .3px; }
  .exam-header .gate-title p { font-size: 11px; color: var(--text-sub); margin-top: 1px; }
  .exam-header .iisc-logo {
    width: 52px; height: 52px; background: #8b0000; border-radius: 50%;
    display: flex; align-items: center; justify-content: center;
    font-size: 9px; font-weight: 900; color: #fff; text-align: center; line-height: 1.3;
    flex-shrink: 0;
  }

  /* Exam Bar */
  .exam-bar {
    background: #1a1a2e;
    color: #fff;
    height: var(--bar-h);
    display: flex;
    align-items: center;
    padding: 0 16px;
    gap: 16px;
    flex-shrink: 0;
    z-index: 99;
  }
  .exam-bar .exam-name { font-size: 12px; font-weight: 700; }
  .exam-bar .bar-btns { margin-left: auto; display: flex; gap: 8px; }
  .exam-bar .bar-btn {
    background: none; border: 1px solid rgba(255,255,255,.35); color: #fff;
    padding: 4px 12px; font-size: 11px; font-family: Arial, sans-serif;
    cursor: pointer; border-radius: 2px; display: flex; align-items: center; gap: 5px;
    transition: border-color .15s;
  }
  .exam-bar .bar-btn:hover { border-color: rgba(255,255,255,.7); }
  .exam-bar .bar-btn .icon { font-size: 13px; }

  /* Section tabs area */
  .section-bar {
    background: #e8e8e8;
    border-bottom: 1px solid var(--border);
    display: flex;
    align-items: center;
    padding: 0 12px;
    height: 38px;
    gap: 4px;
    flex-shrink: 0;
  }
  .section-bar .sec-label { font-size: 11px; color: var(--text-sub); margin-right: 6px; }
  .section-tab {
    background: #d0d0d0; border: 1px solid #bbb; padding: 4px 14px;
    font-size: 12px; font-family: Arial, sans-serif; cursor: pointer;
    border-radius: 2px; color: var(--text); font-weight: 600;
    display: flex; align-items: center; gap: 5px;
  }
  .section-tab.active { background: var(--blue); color: #fff; border-color: var(--blue-dark); }
  .section-tab .info-btn {
    width: 16px; height: 16px; background: rgba(255,255,255,.3); border-radius: 50%;
    font-size: 10px; font-weight: 900; display: inline-flex; align-items: center; justify-content: center;
  }
  .calc-icon-btn {
    margin-left: auto; background: none; border: 1px solid var(--border);
    width: 30px; height: 28px; cursor: pointer; font-size: 16px; border-radius: 3px;
    display: flex; align-items: center; justify-content: center;
  }
  .calc-icon-btn:hover { background: var(--blue-light); }

  /* Main exam body */
  .exam-body {
    display: flex;
    flex: 1;
    overflow: hidden;
  }

  /* Left: Question area */
  .question-panel {
    flex: 1;
    display: flex;
    flex-direction: column;
    overflow: hidden;
    border-right: 1px solid var(--border);
  }

  /* Metadata row */
  .q-meta-bar {
    background: #fff;
    border-bottom: 1px solid var(--border);
    padding: 6px 16px;
    display: flex;
    align-items: center;
    gap: 20px;
    font-size: 12px;
    flex-shrink: 0;
  }
  .q-meta-bar .meta-item { color: var(--text-sub); }
  .q-meta-bar .meta-item strong { color: var(--text); }
  .q-meta-bar .marks-right {
    margin-left: auto;
    color: var(--text-sub);
    font-size: 11px;
  }
  .q-meta-bar .marks-right .pos { color: var(--green); font-weight: 700; }
  .q-meta-bar .marks-right .neg { color: var(--red); font-weight: 700; }

  /* Question content scroll area */
  .q-content {
    flex: 1;
    overflow-y: auto;
    padding: 20px 20px 8px;
    background: #fff;
  }
  .q-number { font-size: 15px; font-weight: 700; margin-bottom: 14px; color: var(--text); }
  .q-statement {
    font-size: 14px; line-height: 1.75; color: var(--text);
    margin-bottom: 22px; font-family: Georgia, serif;
  }
  .q-statement .math { font-family: 'Courier New', monospace; background: #f8f8f8; padding: 1px 5px; border-radius: 2px; font-size: 13px; }
  .q-options { display: flex; flex-direction: column; gap: 10px; }
  .q-option {
    display: flex; align-items: flex-start; gap: 12px;
    padding: 10px 14px; border: 1px solid var(--border);
    border-radius: 3px; cursor: pointer; transition: border-color .12s, background .12s;
    background: #fff;
  }
  .q-option:hover { border-color: var(--blue); background: var(--blue-light); }
  .q-option.selected { border-color: var(--blue); background: var(--blue-light); }
  .q-option input[type="radio"] { margin-top: 1px; width: 16px; height: 16px; accent-color: var(--blue); flex-shrink: 0; cursor: pointer; }
  .q-option label { font-size: 13.5px; color: var(--text); cursor: pointer; font-family: Georgia, serif; line-height: 1.6; flex: 1; }
  .q-option .opt-key { font-weight: 700; min-width: 24px; }
  .nat-input {
    border: 1px solid var(--border); border-radius: 3px;
    padding: 8px 12px; font-size: 14px; width: 200px;
    font-family: Arial, sans-serif; outline: none;
  }
  .nat-input:focus { border-color: var(--blue); }

  /* Year tag */
  .year-tag {
    display: inline-block;
    background: #f9f9f9; border: 1px solid var(--border);
    font-size: 10px; font-weight: 700; color: var(--blue);
    padding: 2px 8px; border-radius: 2px; margin-bottom: 14px;
    text-transform: uppercase; letter-spacing: .4px;
  }

  /* Solution panel */
  .solution-panel {
    margin-top: 20px;
    padding: 14px 16px;
    background: #f0f7e6;
    border: 1px solid #a5d6a7;
    border-radius: 4px;
    display: none;
  }
  .solution-panel.show { display: block; }
  .solution-panel .sol-title { font-size: 12px; font-weight: 700; color: var(--green); margin-bottom: 6px; text-transform: uppercase; letter-spacing: .5px; }
  .solution-panel .sol-answer { font-size: 13px; font-weight: 700; color: var(--green); margin-bottom: 8px; }
  .solution-panel .sol-text { font-size: 13px; line-height: 1.7; color: #2d2d2d; font-family: Georgia, serif; }
  .show-sol-btn {
    margin-top: 14px; padding: 7px 18px; background: none; border: 1px solid var(--green);
    color: var(--green); font-size: 12px; font-weight: 700; cursor: pointer;
    border-radius: 3px; font-family: Arial, sans-serif; letter-spacing: .3px;
  }
  .show-sol-btn:hover { background: #e8f5e9; }

  /* Bottom action bar */
  .q-actions {
    background: #fff;
    border-top: 1px solid var(--border);
    padding: 10px 16px;
    display: flex;
    align-items: center;
    gap: 10px;
    flex-shrink: 0;
  }
  .q-actions .act-left { display: flex; gap: 8px; }
  .q-actions .act-right { margin-left: auto; display: flex; gap: 8px; }
  .btn-review {
    padding: 8px 16px; background: #fff; border: 1px solid #888;
    font-size: 12px; font-weight: 700; cursor: pointer; border-radius: 3px;
    font-family: Arial, sans-serif; color: var(--text); white-space: nowrap;
  }
  .btn-review:hover { background: #f5f5f5; }
  .btn-clear {
    padding: 8px 16px; background: #fff; border: 1px solid #888;
    font-size: 12px; font-weight: 700; cursor: pointer; border-radius: 3px;
    font-family: Arial, sans-serif; color: var(--text);
  }
  .btn-clear:hover { background: #f5f5f5; }
  .btn-save {
    padding: 8px 22px; background: var(--blue); border: 1px solid var(--blue-dark);
    color: #fff; font-size: 12px; font-weight: 700; cursor: pointer; border-radius: 3px;
    font-family: Arial, sans-serif; letter-spacing: .3px;
  }
  .btn-save:hover { background: var(--blue-dark); }
  .btn-submit-exam {
    padding: 8px 22px; background: #1b5e20; border: 1px solid #145214;
    color: #fff; font-size: 12px; font-weight: 700; cursor: pointer; border-radius: 3px;
    font-family: Arial, sans-serif; letter-spacing: .3px;
  }
  .btn-submit-exam:hover { background: #145214; }

  /* ====== RIGHT SIDEBAR ====== */
  .sidebar {
    width: 220px;
    flex-shrink: 0;
    background: #f7f7f7;
    border-left: 1px solid var(--border);
    display: flex;
    flex-direction: column;
    overflow: hidden;
  }

  .sidebar-profile {
    background: #fff;
    border-bottom: 1px solid var(--border);
    padding: 12px;
    display: flex;
    align-items: center;
    gap: 10px;
  }
  .profile-avatar {
    width: 48px; height: 48px; background: #b0bec5; border-radius: 4px;
    display: flex; align-items: center; justify-content: center; font-size: 22px; flex-shrink: 0;
  }
  .profile-name { font-size: 13px; font-weight: 700; color: var(--text); }
  .profile-exam { font-size: 10px; color: var(--text-sub); }

  .sidebar-timer {
    background: #fff;
    border-bottom: 1px solid var(--border);
    padding: 10px 14px;
    text-align: center;
  }
  .timer-label { font-size: 11px; color: var(--text-sub); font-weight: 600; }
  .timer-value {
    font-size: 22px; font-weight: 700; color: var(--text);
    letter-spacing: 2px; font-family: 'Courier New', monospace;
    margin-top: 2px;
  }
  .timer-value.warning { color: var(--red); }

  .sidebar-legend {
    padding: 10px 12px;
    border-bottom: 1px solid var(--border);
    background: #fff;
  }
  .legend-row {
    display: flex; align-items: center; gap: 8px; margin-bottom: 5px; font-size: 11px;
  }
  .legend-box {
    width: 24px; height: 24px; border-radius: 3px;
    display: flex; align-items: center; justify-content: center;
    font-size: 11px; font-weight: 700; color: #fff; flex-shrink: 0;
  }
  .legend-box.answered { background: var(--green-bg); }
  .legend-box.not-answered { background: var(--red-bg); }
  .legend-box.not-visited { background: #9e9e9e; color: #fff; }
  .legend-box.marked { background: var(--purple-bg); }
  .legend-box.answered-marked {
    background: var(--purple-bg);
    border: 3px solid var(--green-bg);
  }
  .legend-label { color: var(--text-sub); }

  .sidebar-palette {
    flex: 1;
    overflow-y: auto;
    padding: 10px;
  }
  .palette-section-title {
    background: var(--blue); color: #fff; font-size: 12px; font-weight: 700;
    padding: 6px 10px; border-radius: 3px 3px 0 0; margin-bottom: 1px;
  }
  .palette-choose { font-size: 10px; color: var(--text-sub); padding: 5px 2px 8px; }
  .palette-grid {
    display: grid; grid-template-columns: repeat(4, 1fr); gap: 5px;
  }
  .pal-btn {
    width: 38px; height: 38px; border: 1px solid #ccc; border-radius: 3px;
    font-size: 12px; font-weight: 700; cursor: pointer; background: #9e9e9e; color: #fff;
    font-family: Arial, sans-serif; transition: all .12s;
    display: flex; align-items: center; justify-content: center;
  }
  .pal-btn.current { background: var(--orange); border-color: #bf360c; transform: scale(1.08); }
  .pal-btn.answered { background: var(--green-bg); border-color: var(--green); }
  .pal-btn.marked { background: var(--purple-bg); border-color: var(--purple); }
  .pal-btn.answered-marked { background: var(--purple-bg); border-color: var(--green-bg); border-width: 2px; }
  .pal-btn:hover { filter: brightness(1.1); }

  /* ====== INSTRUCTIONS MODAL ====== */
  .modal-overlay {
    position: fixed; inset: 0; background: rgba(0,0,0,.6);
    z-index: 999; display: none; align-items: center; justify-content: center;
  }
  .modal-overlay.show { display: flex; }
  .modal-box {
    background: #fff; border-radius: 4px; max-width: 640px; width: 96%;
    max-height: 85vh; overflow-y: auto; box-shadow: 0 8px 32px rgba(0,0,0,.3);
  }
  .modal-header {
    background: var(--blue); color: #fff; padding: 14px 18px;
    display: flex; align-items: center; justify-content: space-between;
    border-radius: 4px 4px 0 0;
  }
  .modal-header h3 { font-size: 14px; font-weight: 700; }
  .modal-close { background: none; border: none; color: #fff; font-size: 20px; cursor: pointer; font-weight: 700; }
  .modal-body { padding: 20px; font-size: 13px; line-height: 1.75; color: var(--text); }
  .modal-body h4 { font-size: 13px; font-weight: 700; color: var(--blue); margin: 14px 0 6px; }
  .modal-body ul { padding-left: 18px; }
  .modal-body li { margin-bottom: 6px; }
  .modal-footer { padding: 14px 20px; border-top: 1px solid var(--border); text-align: right; }

  /* ====== SUBMIT CONFIRM MODAL ====== */
  .submit-modal .modal-box { max-width: 440px; }
  .submit-modal .modal-header { background: #1b5e20; }
  .submit-stats { display: flex; gap: 10px; flex-wrap: wrap; margin: 14px 0; }
  .submit-stat {
    flex: 1; min-width: 90px; text-align: center;
    border: 1px solid var(--border); border-radius: 4px; padding: 10px 8px;
  }
  .submit-stat .stat-n { font-size: 22px; font-weight: 700; }
  .submit-stat .stat-l { font-size: 10px; color: var(--text-sub); font-weight: 700; text-transform: uppercase; }
  .submit-stat.answered .stat-n { color: var(--green-bg); }
  .submit-stat.not-ans .stat-n { color: var(--red-bg); }
  .submit-stat.marked .stat-n { color: var(--purple-bg); }
  .submit-stat.not-vis .stat-n { color: #9e9e9e; }
  .modal-btn-row { display: flex; gap: 10px; justify-content: flex-end; }
  .btn-modal-cancel { padding: 8px 18px; background: #fff; border: 1px solid #888; font-size: 12px; font-weight: 700; cursor: pointer; border-radius: 3px; font-family: Arial, sans-serif; }
  .btn-modal-submit { padding: 8px 22px; background: var(--blue); color: #fff; border: none; font-size: 12px; font-weight: 700; cursor: pointer; border-radius: 3px; font-family: Arial, sans-serif; }

  /* ====== RESULTS SCREEN ====== */
  #result-screen {
    display: none;
    min-height: 100vh;
    background: var(--grey-bg);
    flex-direction: column;
  }
  .result-header {
    background: var(--blue); color: #fff; padding: 0 32px;
    height: 64px; display: flex; align-items: center; gap: 14px;
  }
  .result-header h2 { font-size: 18px; font-weight: 700; }
  .result-body { max-width: 860px; margin: 0 auto; padding: 32px 24px 60px; }
  .result-card {
    background: #fff; border: 1px solid var(--border); border-radius: 6px;
    padding: 28px; margin-bottom: 20px;
  }
  .result-card h3 { font-size: 16px; font-weight: 700; color: var(--blue); margin-bottom: 16px; padding-bottom: 10px; border-bottom: 1px solid var(--border); }
  .score-big { text-align: center; margin: 10px 0 20px; }
  .score-big .score-num { font-size: 60px; font-weight: 700; color: var(--blue); line-height: 1; }
  .score-big .score-label { font-size: 13px; color: var(--text-sub); margin-top: 4px; }
  .score-big .score-max { font-size: 20px; color: var(--text-sub); }
  .result-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 12px; margin-bottom: 16px; }
  .result-stat { background: var(--grey-bg); border-radius: 4px; padding: 14px; border: 1px solid var(--border); }
  .result-stat .rs-num { font-size: 24px; font-weight: 700; }
  .result-stat .rs-label { font-size: 11px; color: var(--text-sub); font-weight: 700; text-transform: uppercase; margin-top: 2px; }
  .result-stat.green .rs-num { color: var(--green-bg); }
